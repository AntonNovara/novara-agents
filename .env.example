# === Novara Agent Factory – Environment Template ===
# Copy to .env and fill in your values. Never commit .env to version control.

# LLM Provider
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# API Security
API_SECRET_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key

# CRM / ERP Mock
CRM_ENDPOINT=https://crm.internal/api/v1
CRM_API_KEY=mock-key

# Google Calendar (book_appointment Tool für Voice Agent)
# Anleitung: python get_token.py ausführen → Werte hierher kopieren
GOOGLE_CLIENT_ID=<aus Google Cloud Console – OAuth 2.0 Client ID>
GOOGLE_CLIENT_SECRET=<aus Google Cloud Console – OAuth 2.0 Client Secret>
GOOGLE_REFRESH_TOKEN=<einmalig via get_token.py generieren>

# DSGVO / Data Residency
DATA_RESIDENCY_REGION=eu-central-1
ENABLE_PII_REDACTION=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Environment — in Railway auf "production" setzen (deaktiviert Swagger UI + API-Key-Bypass)
ENVIRONMENT=production
